generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── REGION ────────────────────────────────────────────
model Region {
  id          String   @id @default(cuid())
  name        String   @unique
  state       String?
  description String?  @db.Text
  climateZone String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  suppliers    Supplier[]
  availability PlantAvailability[]
  chatSessions ChatSession[]
  designs      Design[]
}

// ─── SUPPLIER ──────────────────────────────────────────
model Supplier {
  id       String  @id @default(cuid())
  name     String
  regionId String
  region   Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)
  address  String?
  city     String?
  state    String?
  zip      String?
  phone    String?
  email    String?
  website  String?
  notes    String? @db.Text
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  availability PlantAvailability[]

  @@index([regionId])
  @@index([isActive])
}

// ─── PLANT ─────────────────────────────────────────────
model Plant {
  id         String @id @default(cuid())
  commonName String

  // AI-populated fields
  botanicalName   String?
  alternateNames  String[]  @default([])
  plantType       String?
  family          String?
  hardinessZoneMin String?
  hardinessZoneMax String?
  sunRequirement  String?
  waterNeeds      String?
  soilPreference  String?  @db.Text
  matureHeight    String?
  matureWidth     String?
  // Parsed numeric values in feet. Strings above stay the source of truth for display;
  // these are derived by the backfill script and used by layout math.
  matureHeightFeet Float?
  matureWidthFeet  Float?
  growthRate      String?
  bloomTime       String?
  bloomColor      String?
  foliageColor    String?
  nativeRegion    String?  @db.Text
  description     String?  @db.Text
  careTips        String?  @db.Text
  companionPlants String[] @default([])
  imageUrl        String?

  // AI metadata
  aiPopulated   Boolean   @default(false)
  aiPopulatedAt DateTime?
  aiModel       String?
  aiConfidence  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  availability PlantAvailability[]

  @@index([commonName])
  @@index([botanicalName])
  @@index([plantType])
  @@index([sunRequirement])
  @@index([waterNeeds])
  @@index([aiPopulated])
}

// ─── PLANT AVAILABILITY ────────────────────────────────
model PlantAvailability {
  id         String @id @default(cuid())
  plantId    String
  plant      Plant  @relation(fields: [plantId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  regionId   String
  region     Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  price      Decimal? @db.Decimal(10, 2)
  size       String?
  inStock    Boolean  @default(true)
  stockNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([plantId, supplierId, size])
  @@index([plantId])
  @@index([supplierId])
  @@index([regionId])
  @@index([inStock])
}

// ─── UPLOAD LOG ────────────────────────────────────────
model UploadLog {
  id           String    @id @default(cuid())
  fileName     String
  supplierId   String?
  regionId     String?
  rowCount     Int
  successCount Int       @default(0)
  errorCount   Int       @default(0)
  errors       Json?
  status       String    @default("pending")
  uploadedBy   String
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
}

// ─── CHAT ──────────────────────────────────────────────
model ChatSession {
  id       String  @id @default(cuid())
  userId   String?
  regionId String?
  region   Region? @relation(fields: [regionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@index([userId])
}

model ChatMessage {
  id             String      @id @default(cuid())
  sessionId      String
  session        ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role           String
  content        String      @db.Text
  sourcePlantIds String[]    @default([])
  createdAt      DateTime    @default(now())

  @@index([sessionId])
}

// ─── DESIGN ────────────────────────────────────────────
// A user-owned landscape design for a single bed.
// Bed geometry, chat transcript, plant shortlist, and generated layout
// all live together so the design can be resumed across sessions.
model Design {
  id       String  @id @default(cuid())
  userId   String  // Clerk userId (not a DB relation)
  regionId String
  region   Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)

  name String @default("Untitled design")

  // Bed geometry: polygon vertices in feet, origin = bottom-left.
  // Stored as JSON for flexibility (any vertex count, shape).
  bedPolygon Json?
  // Original bed image (user upload) — used for visual reference and
  // to re-derive the polygon if they want to edit it later.
  bedImageUrl String?
  // Which cardinal direction the "front" (bottom edge in local coords)
  // of the bed faces. Used to compute sun exposure per plant location.
  sunOrientation String? // "N" | "S" | "E" | "W"

  // Plants selected for this design. Auto-populated by the consult chat
  // and editable by the user in the UI.
  shortlistPlantIds String[] @default([])

  // Chat transcript for the consult tab.
  messages Json @default("[]")

  // Generated scaled layout from the generator tab.
  // Shape: { placements: [{plantId, x, y, spreadRadius, quantity}], notes, createdAt }
  layout Json?

  status String @default("draft") // "draft" | "generated"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt(sort: Desc)])
  @@index([regionId])
}
